pragma solidity ^0.8.20;

// Basic Data Types 4: String literals
// msg1: bytes32 for short string, msg2: string for long string (>32 bytes)
contract Contract {
    bytes32 public msg1 = "Blockchain is the future";
    string public msg2 = "Solidity enables developers to write smart contracts on Ethereum and other EVM chains.";
}

